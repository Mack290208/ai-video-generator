# ========== GPT-SoVITS 本地 API 配置 ==========
TTS_PROVIDER=gpt_sovits
GPT_SOVITS_BASE_URL=http://127.0.0.1:9880

# 默认参考音频 & 参考文本（可被 segment 里的 ref_audio_path / prompt_text 覆盖）
GPT_SOVITS_REF_AUDIO=C:\Users\hymac\.openclaw\workspace\assets\ref_audio\mack_ref_01.mp3
GPT_SOVITS_PROMPT_TEXT=ai助教视频测试音频
GPT_SOVITS_PROMPT_LANG=zh

# 合成文本默认语言
GPT_SOVITS_TEXT_LANG=zh

# 其它推理参数
# ⚠️ 经验：长文本（>50字）必须用 cut5 或 cut1（按标点切），不能用 cut0（会截断丢字）。
GPT_SOVITS_SPLIT=cut5
GPT_SOVITS_BATCH_SIZE=1
GPT_SOVITS_MEDIA_TYPE=wav
GPT_SOVITS_STREAMING=false
GPT_SOVITS_SPEED=1.0
GPT_SOVITS_TIMEOUT=300
